        },
        {
          "id": "n4",
          "type": "action",
          "action": "assert:element",
          "selector": "a[href='/signup']",
          "label": "Assert Sign up link exists"
        },
        {
          "id": "n5",
          "type": "action",
          "action": "assert:element",
          "selector": "a[rel='nofollow'][href*='/pricing']",
