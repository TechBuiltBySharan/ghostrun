{
  "name": "ghostrun-cli",
  "version": "1.0.4",
  "description": "Local-first CLI for browser automation, API testing, and load testing",
  "main": "ghostrun.js",
  "bin": {
    "ghostrun": "./ghostrun.js"
  },
  "scripts": {
    "build": "npx tsc -p apps/cli/tsconfig.json",
    "dev": "npx tsx ghostrun.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:flows": "node scripts/comprehensive-reliability-test.mjs",
    "test:edge": "node scripts/run-edge-tests.mjs",
    "test:explore": "node scripts/run-explore-tests.mjs",
    "test:visual": "node scripts/run-visual-tests.mjs",
    "test:benchmark": "node scripts/run-benchmark.mjs",
    "test:all": "npm run test && npm run test:flows",
    "validate": "npm run build && npm run test",
    "lint": "eslint . --ext .ts,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.js,.mjs --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["browser-automation", "api-testing", "playwright", "cli"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@clack/prompts": "^0.7.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "keytar": "^7.9.0",
    "ollama": "^0.5.14",
    "playwright": "^1.50.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
