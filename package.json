{
  "name": "ghostrun-cli",
  "version": "2.0.0-alpha.13",
  "description": "Local-first CLI for browser automation, API testing, and load testing",
  "repository": {
    "type": "git",
    "url": "https://github.com/TechBuiltBySharan/ghostrun.git"
  },
  "bugs": {
    "url": "https://github.com/TechBuiltBySharan/ghostrun/issues"
  },
  "homepage": "https://github.com/TechBuiltBySharan/ghostrun#readme",
  "main": "ghostrun.js",
  "files": [
    "ghostrun.js",
    "mcp-server.js",
    "README.md",
    "AGENTS.md",
    "MCP-SETUP.md",
    "REFERENCE.md",
    "CHANGELOG.md",
    "LICENSE",
    "templates/"
  ],
  "bin": {
    "ghostrun": "./ghostrun.js",
    "ghostrun-mcp": "./mcp-server.js"
  },
  "scripts": {
    "build": "npm run typecheck && npm run build:bin",
    "build:bin": "esbuild ghostrun.ts --bundle --platform=node --format=cjs --target=node18 --packages=external --outfile=ghostrun.js && esbuild mcp-server.ts --bundle --platform=node --format=cjs --target=node18 --packages=external --outfile=mcp-server.js && chmod +x ghostrun.js mcp-server.js",
    "dev": "npx tsx ghostrun.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:api": "vitest run tests/e2e/api.test.ts",
    "test:browser": "vitest run tests/e2e/browser.test.ts",
    "test:ci": "npm run test:unit && npm run test:e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "vitest run --config vitest.visual.config.ts",
    "test:all": "npm run test && npm run test:visual",
    "validate": "npm run build && npm run test",
    "smoke:package": "npm run build && node scripts/smoke-test-package.mjs",
    "publish:check": "node scripts/publish-safety-check.mjs",
    "prepublishOnly": "npm run build && npm run publish:check",
    "lint": "eslint . --ext .ts,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.js,.mjs --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.release.json"
  },
  "keywords": [
    "qa-agent",
    "qa-automation",
    "test-agent",
    "ai-testing",
    "browser-automation",
    "api-testing",
    "playwright",
    "cli",
    "mcp",
    "mcp-server",
    "test-automation",
    "load-testing",
    "regression-testing",
    "e2e",
    "local-first"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@clack/prompts": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^9.6.0",
    "chalk": "^4.1.2",
    "keytar": "^7.9.0",
    "node-cron": "^4.6.0",
    "ollama": "^0.6.3",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.19.43",
    "@types/node-cron": "^3.0.11",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.18.0",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  }
}
